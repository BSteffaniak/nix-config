{
    "$schema": "https://opencode.ai/config.json",
    "autoupdate": false,
    "formatter": {
        "rustfmt": {
            "command": ["rustfmt", "$FILE"],
            "extensions": [".rs"]
        },
        "taplo": {
            "command": ["taplo", "fmt", "$FILE"],
            "extensions": [".toml"]
        },
        "prettierd": {
            "command": ["prettierd", "$FILE"],
            "extensions": [".md", ".yaml", ".yml"]
        }
    },
    "lsp": {
        "rust": {
            "disabled": true
        },
        "lspmux": {
            "command": ["lspmux"],
            "extensions": [".rs"]
        }
    },
    "agent": {
        "build": {
            "mode": "primary",
            "tools": {
                "write": true,
                "edit": true,
                "bash": true
            },
            "permission": {
                "bash": {
                    "*": "allow"
                },
                "external_directory": "allow"
            }
        },
        "plan": {
            "mode": "primary",
            "tools": {
                "write": false,
                "edit": false,
                "bash": true
            },
            "permission": {
                "bash": {
                    "*": "deny"
                },
                "external_directory": "allow"
            }
        }
    }
}
