{
    "agent": {
        "build": {
            "permission": {
                "bash": {
                    "brew install *": "deny",
                    "brew uninstall *": "deny",
                    "brew remove *": "deny",
                    "brew upgrade *": "deny",
                    "brew tap *": "deny",
                    "brew untap *": "deny",
                    "brew cleanup *": "deny",
                    "brew autoremove *": "deny",
                    "brew link *": "deny",
                    "brew unlink *": "deny",
                    "brew pin *": "deny",
                    "brew unpin *": "deny",
                    "brew services start *": "deny",
                    "brew services stop *": "deny",
                    "brew services restart *": "deny"
                }
            }
        },
        "plan": {
            "permission": {
                "bash": {
                    "brew *": "deny",
                    "brew list": "allow",
                    "brew list *": "allow",
                    "brew info *": "allow",
                    "brew deps *": "allow",
                    "brew search *": "allow",
                    "brew leaves": "allow",
                    "brew leaves *": "allow",
                    "brew outdated": "allow",
                    "brew outdated *": "allow",
                    "brew config": "allow",
                    "brew doctor": "allow",
                    "brew --version": "allow",
                    "brew help *": "allow",
                    "brew desc *": "allow",
                    "brew cat *": "allow",
                    "brew home *": "allow",
                    "brew uses *": "allow",
                    "brew services list": "allow",
                    "brew services list *": "allow",
                    "brew tap-info *": "allow"
                }
            }
        }
    }
}
