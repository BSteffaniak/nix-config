{
    "flakeInput": "bcode-src",
    "buildSystem": "rust",
    "pname": "bcode",
    "hashField": "cargoHash",
    "doCheck": false,
    "nativeBuildInputs": ["pkg-config", "cmake"],
    "buildInputs": ["openssl", "libiconv"],
    "rustToolchain": "stable",
    "env": {
        "BCODE_TESSERACT_ARTIFACT_CACHE": "/tmp/bcode-tesseract-artifacts",
        "BCODE_TESSERACT_SOURCE_CACHE": "/tmp/bcode-tesseract-sources"
    },
    "cargoBuildFlags": ["--package", "bcode", "--features", "app"]
}
