{
    "owner": "badlogic",
    "repo": "pi-mono",
    "pname": "pi",
    "binaryName": "pi",
    "installedBinaryName": "pi",
    "installMode": "directory",
    "stripVersionPrefix": "v",
    "platforms": {
        "x86_64-linux": "pi-linux-x64.tar.gz",
        "aarch64-linux": "pi-linux-arm64.tar.gz",
        "x86_64-darwin": "pi-darwin-x64.tar.gz",
        "aarch64-darwin": "pi-darwin-arm64.tar.gz"
    },
    "runtimeDeps": {
        "npm": {
            "packageJsonPath": "libexec/pi/package.json",
            "artifactPackageJsonPath": "package.json",
            "syncFromArtifactPackageJson": [
                {
                    "section": "optionalDependencies",
                    "name": "@mariozechner/clipboard"
                }
            ],
            "nodeModulesPath": "libexec/pi/node_modules",
            "wrapExecutables": {
                "pi": {
                    "exec": "@out@/libexec/pi/pi",
                    "env": {
                        "BUN_INSTALL": "$HOME/.pi/agent/bun",
                        "NODE_PATH": "@out@/libexec/pi/node_modules${NODE_PATH:+:$NODE_PATH}"
                    }
                }
            }
        }
    },
    "meta": {
        "description": "Pi interactive coding agent CLI (from pi-mono GitHub releases)",
        "homepage": "https://github.com/badlogic/pi-mono",
        "license": "mit"
    }
}
